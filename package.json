{
  "name": "neatspace-specs",
  "version": "0.1.0",
  "private": true,
  "description": "Contratos spec-driven de NeatSpace (OpenAPI/AsyncAPI) y sus gates de calidad.",
  "scripts": {
    "lint:openapi": "spectral lint specs/openapi.yaml",
    "lint:asyncapi": "spectral lint specs/asyncapi.yaml",
    "lint:specs": "spectral lint specs/openapi.yaml specs/asyncapi.yaml",
    "gen:types": "openapi-typescript specs/openapi.yaml -o types/openapi.ts",
    "docs:api": "npx --yes @redocly/cli@latest build-docs specs/openapi.yaml -o api-docs.html",
    "qa": "npm run lint:specs"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.14.2",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
